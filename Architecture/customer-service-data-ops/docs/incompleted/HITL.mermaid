graph TD
    subgraph Ingesta_y_Seguridad_HITL
    A[Logs de Red/Cloud] --> B[Python/Bash Scraper]
    B --> C{Data Masking Layer}
    C -->|Hash SHA256 + Salt| D[S3 Bucket: Landing]
    
    %% Punto de intervención Humana 1
    H1{{"<b>HUMAN: Definición de PII</b><br/>¿Qué datos son sensibles?<br/>(Legal/Compliance)"}} -.-> C
    end

    subgraph Procesamiento_y_Calidad
    D --> E[DuckDB: Transformación]
    E --> F[dbt-core: Modelado SQL]
    
    %% Punto de intervención Humana 2
    H2{{"<b>HUMAN: Reglas de Negocio</b><br/>¿Qué es un 'incidente real'?<br/>(Filtros de Negocio)"}} -.-> F
    
    %% Punto de intervención Humana 3
    F --> T[dbt Tests / Great Expectations]
    H3{{"<b>HUMAN: Umbral de Error</b><br/>¿Cuánta pérdida de datos<br/>tolera el negocio?"}} -.-> T
    end

    subgraph Entrega_y_Valor_Business
    T --> G[(PostgreSQL/BigQuery)]
    G --> I[Dashboard / Alerts]
    
    %% Punto de intervención Humana 4
    H4{{"<b>HUMAN: Storytelling</b><br/>¿Cómo explicamos esto<br/>al CISO/CEO?"}} -.-> I
    end

    style H1 fill:#ffd700,stroke:#333,stroke-width:2px
    style H2 fill:#ffd700,stroke:#333,stroke-width:2px
    style H3 fill:#ffd700,stroke:#333,stroke-width:2px
    style H4 fill:#ffd700,stroke:#333,stroke-width:2px
    style C fill:#f96,stroke:#333,stroke-width:4px

<?xml version="1.0" encoding="UTF-8"?>
<StarSchema name="CustomerSupport_StarSchema">

    <!-- TABLA DE HECHOS CENTRAL -->
    <FactTable name="Fact_Tickets">
        <Keys>
            <ForeignKey name="FK_Customer" references="Dim_Customers" />
            <ForeignKey name="FK_Product" references="Dim_Products" />
            <ForeignKey name="FK_Agent" references="Dim_Agents" />
            <ForeignKey name="FK_Date" references="Dim_Date" />
        </Keys>
        <Measures>
            <Measure name="First_Response_Time" type="DateTime" />
            <Measure name="Time_to_Resolution" type="Duration" />
            <Measure name="Customer_Satisfaction_Rating" type="Integer" />
        </Measures>
        <Attributes>
            <Attribute name="Ticket_ID" type="String" />
            <Attribute name="Status" type="String" />
        </Attributes>
    </FactTable>

    <!-- DIMENSIONES -->
    <Dimensions>
        <Dimension name="Dim_Customers">
            <Columns>
                <Column name="Customer_Name" />
                <Column name="Customer_Email" />
                <Column name="Customer_Age" />
                <Column name="Gender_Gender" />
            </Columns>
        </Dimension>

        <Dimension name="Dim_Products">
            <Columns>
                <Column name="Product_ID_Name" />
                <Column name="Purchase_Date" />
            </Columns>
        </Dimension>

        <Dimension name="Dim_Agents">
            <Columns>
                <Column name="Agent_ID_Name" />
                <Column name="Agent_Team" />
                <Column name="Agent_Role" />
            </Columns>
        </Dimension>

        <Dimension name="Dim_Date">
            <Columns>
                <Column name="Full_Date_Year" />
                <Column name="Month_of_Week" />
                <Column name="Day_of_Quarter" />
            </Columns>
        </Dimension>
    </Dimensions>

</StarSchema>


